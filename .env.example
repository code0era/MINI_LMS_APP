# CourseWave — Mini LMS
# React Native Expo App

# ── MANDATORY ──────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=https://api.freeapi.app

# ── AI Recommendations (Groq — free) ───────────────────────
GROQ_API_KEY=your_groq_key_here

# ── Error Tracking (Sentry — free) ─────────────────────────
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ── Analytics (PostHog — free) ─────────────────────────────
EXPO_PUBLIC_POSTHOG_KEY=your_posthog_key_here
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── EAS Build ──────────────────────────────────────────────
# EXPO_TOKEN is set as a GitHub Actions secret — never in .env
